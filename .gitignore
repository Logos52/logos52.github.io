# OS and editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Obsidian local state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspaces.json
.obsidian/cache
.obsidian/plugins/
.obsidian/trash/
.trash/

# Raw source material stays local; keep only the public architecture skeleton.
raw/**
!raw/
!raw/Source Index.md
!raw/assets/
!raw/assets/.gitkeep
!raw/datasets/
!raw/datasets/.gitkeep
!raw/images/
!raw/images/.gitkeep
!raw/papers/
!raw/papers/.gitkeep
!raw/repos/
!raw/repos/.gitkeep
!raw/sources/
!raw/sources/.gitkeep

# Private working pages stay local.
private/**
!private/
!private/Goals/
!private/Goals/.gitkeep
!private/Goals/Priority 0.md
!private/Skills/
!private/Skills/.gitkeep

# Secrets and local config
.env
.env.*
*.key
*.pem

# Generated caches
.cache/
node_modules/
__pycache__/
*.pyc

# Quartz build output and caches
public/
.quartz-cache/
